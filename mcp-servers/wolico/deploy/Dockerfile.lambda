FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml server.py api.py helpers.py ./
COPY tools/ ./tools/

RUN pip install --no-cache-dir mcp httpx python-dotenv uvicorn starlette boto3

# Lambda Web Adapter: il server HTTP gira sulla porta 8080
# LWA traduce gli eventi Lambda in richieste HTTP
ENV PORT=8080
ENV MCP_TRANSPORT=http

EXPOSE 8080

CMD ["python", "server.py"]
